{% macro brochures(lang) %}
  <ul class="buttons">
    {% if lang == 'fr' %}
      <li><a href="{{ url_for('static', filename='brochures/brochure_fr.pdf') }}">Brochure de sponsoring</a></li>
    {% elif lang == 'en' %}
      <li><a href="{{ url_for('static', filename='brochures/brochure_en.pdf') }}">Sponsoring brochure</a></li>
    {% endif %}
  </ul>
{% endmacro %}

{% macro description(company, lang) %}
  <div class="description">
    {% if lang == 'fr' %}
      {% if company == 'estia' %}
        <p>
          L'ESTIA, un environnement d'apprentissage dynamique et stimulant qui favorise l'émergence de talents dans les domaines technologiques avancés.
        </p>
      {% elif company == 'Yaal Coop' %}
        <p>Yaal Coop est une société coopérative d'intérêt collectif (SCIC)
          spécialisée dans le conseil, le développement et l'hébergement de
          services informatiques. La coopérative est située à Bordeaux et est
          composée de 5 personnes associées salariées, et 2 personnes salariées.
          Python est le langage de prédilection utilisé pour le développement de
          service web, scripts, logiciels libres et la plupart des projets de la
          coopérative.<br/>
          Yaal Coop prend soin de contribuer aux brique logicielles libres
          qu'elle emploie, par la correction de bugs, l'implémentation de
          fonctionnalités, ou la co-maintenance de certains projets.</p>

      {% elif company == 'Mergify' %}
         <p>Mergify aide les équipes de développement à livrer plus vite sans 
         casser la branche principale. Notre merge queue teste et fusionne 
         automatiquement les pull requests dans le bon ordre, en regroupant et 
         parallélisant la CI : fini de surveiller les merges à la main et de 
         payer des builds redondants. Au-delà de la file, Mergify ajoute les 
         merge protections (des règles pour encadrer quand et comment le code 
         est fusionné) et CI Insights, qui détecte et met en quarantaine les 
         tests instables pour qu'un build rouge veuille enfin dire quelque 
         chose. Conçu par des développeurs open source de longue date, Mergify 
         est utilisé aussi bien par des startups en forte croissance que par 
         certaines des plus grandes organisations d'ingénierie au monde. 
         L'objectif est simple : garder votre branche principale verte, votre 
         CI rapide et économique, et vos développeurs concentrés sur le 
         code plutôt que sur le processus de merge.</p>
      {% elif company == 'Descartes' %}
        <p>Descartes est un acteur de l'assurance pour les entreprises et les institutions né de la conviction que la complexité croissante des risques climatiques exige une nouvelle approche. Descartes utilise la technologie associée à des sources de données météorologiques, pour modéliser, évaluer et gérer les risques.<br/>
        Combinant expertise scientifique et technologique, Descartes est reconnu dans le secteur de l'assurance paramétrique. Lorsqu'un événement dépasse le seuil d’une police, l'assurance paramétrique indemnise les clients en quelques jours sur la base de sources de données et de structures de paiement prédéfinies. Le processus est rapide et transparent. Descartes a reçu plusieurs prix et fait partie de la cohorte 2026 Next40 de la FrenchTech.<br/>
        Descartes compte plus de 250 employés. C’est la plus grande équipe de modélisation du secteur, avec des scientifiques en physique et en climatologie, des développeurs, ainsi que des vétérans de l'assurance et des souscripteurs.</p>
      {% endif %}
    {% elif lang == 'en' %}
      {% if company == 'estia' %}
        <p>
          ESTIA, a dynamic and stimulating learning environment that fosters the emergence of talent in advanced technological fields.
        </p>
      {% elif company == "Yaal Coop" %}
        <p>
          Yaal Coop is a cooperative specialized in consulting, development and services hosting.
          The company is located in Bordeaux and has 5 salaried partners.
          Python is our favorite language to write web services, scripts, free software and almost every cooperative projects.
        </p>
      {% elif company == 'Mergify' %}
        <p>Mergify helps engineering teams ship code faster without breaking main.
        Our merge queue automatically tests and merges pull requests in the 
        right order, batching and parallelizing CI so teams stop babysitting 
        merges and stop paying for redundant builds. Beyond the queue, Mergify 
        adds merge protections (rules for how and when code lands) and 
        CI Insights, which detects and quarantines flaky tests so a red build 
        finally means something. Built by long-time open source developers, 
        Mergify is used by teams from fast-growing startups to some of the 
        largest engineering organizations in the world. The goal is simple: 
        keep your main branch green, your CI fast and cheap, and your developers
        focused on writing code instead of fighting the merge process.</p>
      {% elif company == 'Descartes' %}
        <p>Descartes is an insurance group for companies and institutions. It was born from a conviction that the growing complexity of climate risks demands a new approach. At the forefront of data analysis, Descartes uses technology combined with weather data sources, to model, assess and manage risks.<br/>

        Descartes has secured a leading position in parametric insurance combining scientific & technological expertise. When a specific triggering event occurs, parametric insurance indemnifies clients within days based on pre-defined data sources and payout structures. The process is fast and transparent. Descartes has received several awards and is a member of the 2026 edition of the Next40 by the French Tech.<br/>

        Descartes’ diverse and specialized team of 250+ people includes the largest modelling team in the industry featuring tech and modeling innovators, scientists in physics and climatology, as well as insurance veterans and underwriters.</p> 
      {% endif %}
    {% endif %}
  </div>
{% endmacro %}


{% macro sponsors(lang, only_logo=False) %}
  {% set levels = {
      'Platine' if lang == 'fr' else 'Platinum': {
          'estia': 'https://www.estia.fr/',
      },

      'Or' if lang == 'fr' else 'Gold': {
          'Mergify': 'https://mergify.com/',
      },

      'Argent' if lang == 'fr' else 'Silver': {},

      'Bronze': {
          'Yaal Coop': 'https://yaal.coop/',
          'Descartes': 'https://descartesunderwriting.com/',
      },

      'Cœur' if lang == 'fr' else 'Heart': {
          'WeasyPrint': 'https://weasyprint.org/',
      },

      'Partenaires' if lang == 'fr' else 'Partners': {
          'Annabelle Nicvert': 'https://www.linkedin.com/in/annabelle-nicvert-158127373/',
      },
  } %}

  {% set png_logos = ('estia', 'Descartes') %}

  {% if lang == 'fr' %}
    <p>
      <a href="{{ url_for('page', name='support', lang=lang)}}">Devenez sponsor</a> et
      offrez à votre entreprise une plus grande visibilité lors de cet événement.
    </p>
  {% else %}
    <p>
      <a href="{{ url_for('page', name='support', lang=lang)}}">Become sponsor</a> to
      offer a wider visibility to your enterprise during this event.
    </p>
  {% endif %}

  {{ brochures() }}

  {% for level, companies in levels.items() %}
    {% if companies %}
      <section class="sponsors">
        <h3>{{ level }}</h3>
        {% for company, link in companies.items() %}
            {% if not only_logo and level not in ('Heart', 'Partners', 'Cœur', 'Partenaires') %}
              <div class="sponsor">
                <h4>{{ company }}</h4>
            {% endif %}
            {% if link %}
              <a href="{{ link }}" class="logo">
            {%- endif -%}
              <img src="{{ url_for('static', filename='images/partners/{}.{}'.format(company.replace('/', '-'), 'png' if company in png_logos else 'svg')) }}" alt="Logo {{ company }}" loading="lazy" />
            {%- if link -%}
              </a>
            {% endif %}
            {% if not only_logo and level not in ('Heart', 'Partners', 'Cœur', 'Partenaires') %}
                {{ description(company, lang) }}
              </div>
            {% endif %}
        {% endfor %}
      {% endif %}
    </section>
  {% endfor %}
{% endmacro %}


